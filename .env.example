# Copie este arquivo para .env e ajuste os valores ao seu ofício.

# Caminho da pasta-raiz do workspace "Ofício Geral" do seu ofício.
# Ex.: C:\Users\<seu_usuario>\Desktop\Ofício Geral
# Se vazio, config.py usa ~/Desktop/Ofício Geral.
OFICIO_GERAL=

# Credenciais do SISDPU (para a sincronizacao automatica)
SISDPU_USERNAME=seu.usuario
SISDPU_PASSWORD=sua.senha

# Ajustes do sincronizador (opcional — defaults sensatos em config.py)
RATE_LIMIT_SISDPU_SEG=2
TIMEOUT_TOTAL_SEG=3600
# Limite de anexos baixados por PAJ (30 = default; >= 1 recomendado)
MAX_ANEXOS_POR_PAJ=30

# Timeout por pagina no Tesseract (segundos). Default 30.
# Aumente se voce tem PDFs escaneados muito densos; diminua pra cancelar
# travamentos mais rapido.
TIMEOUT_OCR_POR_PAGINA_SEG=30

# Pasta onde DOCX/PDF gerados sao salvos.
# Default: <OFICIO_GERAL>/Peças Feitas
# DOCGEN_OUT_DIR=C:\caminho\custom\Peças Feitas
